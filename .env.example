


# Node environment (development, production)
NODE_ENV="development"

# Server Port
PORT=3000

# PostgreSQL Database connection strings
DATABASE_URL="postgresql://postgres:password@localhost:5440/ebooklet_db?schema=public"
PRISMA_DATABASE_URL="postgresql://postgres:password@localhost:5440/ebooklet_db?schema=public"

# JWT configuration
JWT_SECRET="supersafesecretkeychangeinproduction"
JWT_EXPIRES_IN="7d"

# Upload and storage directories
UPLOADS_DIR="/uploads"
MAX_FILE_SIZE_MB=5
